      </EntityTypeMapping>
    </EntitySetMapping>
    <FunctionImportMapping FunctionImportName="sp_EstadoEmpleado" FunctionName="examenCrudMVC_NFrameworkModel.Store.sp_EstadoEmpleado" />
    <FunctionImportMapping FunctionImportName="sp_ListarEmpleadoPorIdDep" FunctionName="examenCrudMVC_NFrameworkModel.Store.sp_ListarEmpleadoPorIdDep">
      <ResultMapping>
        <ComplexTypeMapping TypeName="examenCrudMVC_NFrameworkModel.sp_ListarEmpleadoPorIdDep_Result">
          <ScalarProperty Name="idEmpleado" ColumnName="idEmpleado" />
          <ScalarProperty Name="nombreEmpleado" ColumnName="nombreEmpleado" />
