<?xml version="1.0" encoding="utf-8"?>
<Mapping Space="C-S" xmlns="http://schemas.microsoft.com/ado/2009/11/mapping/cs">
  <EntityContainerMapping StorageEntityContainer="examenCrudMVC_NFrameworkModelStoreContainer" CdmEntityContainer="examenCrudMVC_NFrameworkEntities">
    <EntitySetMapping Name="Departamentoes">
      <EntityTypeMapping TypeName="examenCrudMVC_NFrameworkModel.Departamento">
        <MappingFragment StoreEntitySet="Departamento">
          <ScalarProperty Name="idDepartamento" ColumnName="idDepartamento" />
          <ScalarProperty Name="nombreDepartamento" ColumnName="nombreDepartamento" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="Empleadoes">
      <EntityTypeMapping TypeName="examenCrudMVC_NFrameworkModel.Empleado">
        <MappingFragment StoreEntitySet="Empleado">
          <ScalarProperty Name="idEmpleado" ColumnName="idEmpleado" />
          <ScalarProperty Name="nombreEmpleado" ColumnName="nombreEmpleado" />
