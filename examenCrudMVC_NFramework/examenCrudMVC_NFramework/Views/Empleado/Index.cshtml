@model examenCrudMVC_NFramework.ViewModel.EmpleadoVM


@{
    ViewBag.Title = "Gestion Empleados";
}

<div class="container">

    @* --- TARJETA PARA AGREGAR/GUARDAR --- *@
    <div class="mb-3">
        <div class="card shadow-sm">
            <div class="card-header">
                <h2 class="fw-bold">Agregar Usuario</h2>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Guardar", "Empleado", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <div class="d-flex align-items-center mb-3">
                        <label class="fw-bold me-3" style="width: 120px;">Empleado: </label>
                        @Html.TextBoxFor(m => m.EmpleadoModelReference.nombreEmpleado, new { @class = "form-control w-auto", style = "max-width: 300px;", required = "required" })
                    </div>
                    <div class="d-flex align-items-center mb-1">
                        <label class="fw-bold me-3" style="width: 120px;">Departamento: </label>
                        @Html.DropDownListFor(m => m.EmpleadoModelReference.idDepartamento,
                            new SelectList(Model.ListaDepartamentos, "idDepartamento", "nombreDepartamento"),
                            "--Selecciona un Departamento--",
                            new { @class = "form-select w-auto", style = "max-width: 300px;", required = "required" })
                    </div>

                    <button type="submit" class="btn btn-outline-success m-2">
                        <i class="bi bi-save"></i> Guardar
                    </button>
                }
            </div>
        </div>
    </div>

    @* --- TARJETA DE FILTRO --- *@
    <div class="mb-3">
        <div class="card">
            <div class="card-header">
                <h2>Filtro por Departamento</h2>
            </div>
            <div class="card-body d-flex align-items-center">
                <select class="form-select me-3" style="max-width: 300px;" onchange="location.href='@Url.Action("Index", "Empleado")?idDep=' + this.value">
                    <option value="0">--Ver Todo--</option>
                    @foreach (var dep in Model.ListaDepartamentos)
                    {
                        <option value="@dep.idDepartamento" @(dep.idDepartamento == (int?)ViewBag.IdSeleccionado ? "selected='selected'" : "")>
                            @dep.nombreDepartamento
                        </option>
                    }
                </select>
                <a href="@Url.Action("Index", "Empleado")" class="btn btn-outline-info"><i class="bi bi-eraser"></i> Limpiar</a>
            </div>
        </div>
    </div>

    @* --- TABLA DE RESULTADOS --- *@
    <div class="mb-3">
        <table class="table">
            <thead class="table-dark">
                <tr>
                    <th>Id Empleado</th>
                    <th>Nombre Empleado</th>
                    <th>Departamento</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.ListaEmpleados == null || !Model.ListaEmpleados.Any())
                {
                    <tr>
                        <td class="fw-bold" colspan="4">
                            No se encontraron empleados con los requerimientos seleccionados
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var emp in Model.ListaEmpleados)
                    {
                        <tr>
                            <td class="fw-bold">@emp.idEmpleado</td>
                            <td>@emp.nombreEmpleado</td>
                            <td>@(emp.IdDepartamentoNavigation != null ? emp.IdDepartamentoNavigation.nombreDepartamento : "N/A")</td>
                            <td>
                                <div class="d-flex gap-2">
                                    @* FORMULARIO DE ESTADO *@
                                    @using (Html.BeginForm("Estado", "Empleado", FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="idEmp" value="@emp.idEmpleado" />
                                        <input type="hidden" name="idDep" value="@ViewBag.IdSeleccionado" />

                                        var isActive = emp.activo ?? false;

                                        <button type="submit" class="btn @(isActive ? "btn-outline-warning" : "btn-outline-primary")">
                                            @if (isActive)
                                            {
                                                <i class="bi bi-toggle-off"></i> <text>Desactivar</text>
                                            }
                                            else
                                            {
                                                <i class="bi bi-toggle-on"></i> <text>Activar</text>
                                            }
                                        </button>
                                    }

                                    @* ENLACE EDITAR *@
                                    <a href="@Url.Action("Editar", "Empleado", new { idEmp = emp.idEmpleado })" class="btn btn-outline-secondary">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>

                                    @* FORMULARIO ELIMINAR *@
                                    @using (Html.BeginForm("Eliminar", "Empleado", FormMethod.Post, new { onsubmit = "return confirm('¿Seguro que deseas eliminar a " + emp.nombreEmpleado + "?');" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="idEmp" value="@emp.idEmpleado" />
                                        <button type="submit" class="btn btn-outline-danger">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>